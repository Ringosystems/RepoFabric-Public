# RepoFabric Sandbox: version lock for the bundled open-source components.
#
# This is the SANDBOX (throwaway, non-enterprise) deployment. The goal here is
# reproducibility: a sandbox built today should behave like one built later.
#
# Two forms are valid for every image reference:
#   NAME=repo/image:tag                   floating, resolved at build/pull time
#   NAME=repo/image:tag@sha256:<digest>   pinned, byte-reproducible
#
# The committed defaults below are the SAME floating tags the production
# deployment uses today (gitea/gitea:1, rewinged:latest, the node/powershell base
# images). To lock them to digests, run:
#   sandbox/scripts/refresh-versions.sh            # pin to the current latest
# The wizard also offers to pin on first run. Re-running refresh-versions.sh
# re-resolves the floating tags to whatever is newest, matching the production
# process which currently floats on latest.

# Bundled stack images.
GITEA_IMAGE=gitea/gitea:1
REWINGED_IMAGE=ghcr.io/jantari/rewinged:latest
# Highest WinGet manifest schema version the REWINGED_IMAGE above can parse.
# RepoFabric renders every package's manifest down to this (rewinged 404s a manifest
# that declares a newer schema). The sandbox has no docker socket to auto-detect it,
# so this is a MANUAL knob: bump it together with REWINGED_IMAGE whenever you move to a
# rewinged build that supports a newer winget schema (for example 1.12.0). In
# production RepoFabric auto-detects this from the running rewinged, so the knob is
# sandbox-only.
REPOFABRIC_MAX_MANIFEST_VERSION=1.10.0
# NPM is pinned to a tested version, NOT floating :latest. 2.15.x dropped the
# default admin user, which the seed onboarding path (scripts/seed-npm.sh) now
# handles; 2.15.1 is the version the seed + proxy-host setup was validated
# against. Bump deliberately and re-validate seed-npm.sh before changing it.
NPM_IMAGE=jc21/nginx-proxy-manager:2.15.1

# Base images consumed by linux/Dockerfile as build args. Defaults match the
# Dockerfile's own defaults exactly, so the sandbox image and the production
# image share the same base unless these are pinned.
BASE_NODE_IMAGE=node:20-bookworm-slim
BASE_PWSH_IMAGE=mcr.microsoft.com/powershell:lts-debian-12

# Node admin dependency install mode for the sandbox build. `ci` uses a
# generated package-lock.json for a locked layer; `install` (the production
# default) resolves fresh within package.json's semver ranges.
NPM_INSTALL_MODE=install

# Stamp written by refresh-versions.sh. "unpinned" means the values above are
# still floating tags (not yet locked to digests).
RESOLVED_AT=unpinned
