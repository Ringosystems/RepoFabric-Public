# RepoFabric Sandbox runtime settings.
#
# The wizard reads and writes the real file at sandbox/.env (which is
# git-ignored). For an INTERACTIVE run you do not need to create it: the wizard
# prompts for what it needs and generates the secrets. For a --non-interactive
# run, copy this file to sandbox/.env and fill in HOST_ADDRESS and a password.
#
# This is the SANDBOX (throwaway, non-enterprise) deployment. Do not reuse these
# values or this deployment for production.

# Base local domain for the three hostnames: winget./installers./gitea.<domain>.
# .localhost is reserved for loopback (RFC 6761) and never collides with a real
# or corporate zone.
LOCALDOMAIN=repofabric.localhost

# The address your WORKSTATION uses to reach this Docker host (IP or DNS name).
# Used for the printed hosts-file entry. Leave blank to let the wizard detect it.
HOST_ADDRESS=

# HTTPS port published on the Docker host (the only port exposed; no plain HTTP).
SANDBOX_HTTPS_PORT=443

# Local-admin sign-in for the RepoFabric admin UI. In the sandbox this replaces
# Microsoft Entra so the box stands up with zero cloud setup. The password is
# stored only as a scrypt hash inside the container; this file keeps it so a
# --non-interactive run can re-apply it.
SANDBOX_ADMIN_USER=admin
SANDBOX_ADMIN_PASSWORD=

# Generated-once secrets. Leave blank; the wizard fills and persists them.
SANDBOX_SESSION_SECRET=
SANDBOX_NPM_PASSWORD=
GITEA_ADMIN_PASS=

# Display timezone (RepoFabric is the solution authority; use an IANA name).
TZ=UTC
