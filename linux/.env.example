# RepoFabric runtime configuration.
# Copy to the path linux/docker-compose.yml reads (its env_file:, the UNRAID
# default /mnt/cache/appdata/repofabric-linux/.env) and fill in real values
# before first boot. Do not commit this file with secrets (deploy/.env and *.env
# are git-ignored).
#
# RingoSystems Heavy Industries winget repo deployments. See linux/README.md for
# the install walkthrough.

# ------- Host paths (compose substitution; consumed via --env-file) -----
# These tell the compose files WHERE on the host state and appdata live. They
# default to the UNRAID layout INSIDE the compose files, so an UNRAID host can
# leave them unset. On any other host, set them to your chosen roots and run
# compose with `--env-file deploy/.env` (deploy/bootstrap.sh fills these in for
# you). REPOFABRIC_ENV_FILE points the container's env_file at THIS file, so the
# container reads its secrets directly and no separate copy step is needed.
#REPOFABRIC_STATE_ROOT=/mnt/cache/appdata/repofabric-linux
#REPOFABRIC_APPDATA_ROOT=/mnt/user/appdata/repofabric
#REPOFABRIC_ENV_FILE=/opt/repofabric/repo/deploy/.env
# Image source: by default the stack uses the published image
# ringosystems/repofabric:latest (run `docker compose pull` to fetch it, or
# `docker compose build` to build from source instead). Pin a version for
# production.
#REPOFABRIC_IMAGE=ringosystems/repofabric
#REPOFABRIC_IMAGE_TAG=latest
# Optional Gitea web-UI identity (internal traffic uses the container name, so
# these only affect the links Gitea renders):
#GITEA_DOMAIN=gitea.example.com
#GITEA_ROOT_URL=https://gitea.example.com/

# ------- Public-facing URL ----------------------------------------------
# Must match the redirect URI registered on the Entra app. Trailing /admin
# is significant. The wizard at /setup/ is served from the same origin
# until first-run completes, then disabled.
REPOFABRIC_ADMIN_PUBLIC_URL=https://winget.example.com/admin

# ------- Session cookie secret ------------------------------------------
# Generate once with:  openssl rand -hex 32
REPOFABRIC_SESSION_SECRET=

# ------- Entra (Azure AD) app registration ------------------------------
# Created in the Azure portal. Redirect URI on the Entra app must be
# ${REPOFABRIC_ADMIN_PUBLIC_URL}/auth/callback.
REPOFABRIC_ENTRA_TENANT_ID=
REPOFABRIC_ENTRA_CLIENT_ID=
REPOFABRIC_ENTRA_CLIENT_SECRET=

# ------- Authorisation --------------------------------------------------
# Either of these admits a user (configured via the setup wizard, then
# editable in Solution Configuration):
#   - Email (UPN) is in the allow-list.
#   - Any group claim GUID is in the allow-list.
# Stored in /var/lib/repofabric/config/solution.yaml after first run. The env
# vars below are seeds only and only consulted before the wizard saves.
REPOFABRIC_BOOTSTRAP_ALLOWED_EMAILS=
REPOFABRIC_BOOTSTRAP_ALLOWED_GROUPS=

# ------- Gitea target ---------------------------------------------------
# Base URL of the Gitea container reachable from inside the repofabric network.
# PAT must have write access to the winget-manifests repo.
#
# REPOFABRIC_GITEA_REPO is the full 'org/repo' path that the publisher
# pushes manifests to.
REPOFABRIC_GITEA_BASE_URL=http://repofabric-gitea:3000
REPOFABRIC_GITEA_REPO=repofabric-publisher/winget-manifests
REPOFABRIC_GITEA_PAT=
REPOFABRIC_GIT_AUTHOR_NAME=RepoFabric
REPOFABRIC_GIT_AUTHOR_EMAIL=repofabric@example.com

# ------- Installer target -----------------------------------------------
# The publisher writes installer binaries directly to the bind-mounted
# shared volume that the Express installers app serves on host port 8091.
#
# INSTALLER_LOCAL_ROOT is the container-side path the publisher writes
# to (the same path the Express installer server reads from via the
# read-write bind mount in linux/docker-compose.yml). Operators rarely
# change this; the default matches the compose layout.
REPOFABRIC_INSTALLER_LOCAL_ROOT=/var/cache/repofabric/installers
REPOFABRIC_INSTALLER_BASE_URL=https://installers.winget.example.com

# ------- rewinged --------------------------------------------------------
# Used for catalog cross-checks. The authoritative source of "what is in
# the repo" is still the manifest volume walk, this URL is informational.
REPOFABRIC_REWINGED_URL=http://repofabric-rewinged:8080

# ------- SMTP relay (optional, configured in wizard) --------------------
# Host, port, from, and to are configured via the setup wizard or admin UI
# and persist to solution.yaml. Username and password are env-only so the
# password never lands on disk. Leave blank to disable SMTP auth (open
# relay or internal MX).
REPOFABRIC_SMTP_HOST=
REPOFABRIC_SMTP_PORT=25
REPOFABRIC_SMTP_FROM=
REPOFABRIC_SMTP_TO=
REPOFABRIC_SMTP_USERNAME=
REPOFABRIC_SMTP_PASSWORD=

# ------- Container behaviour --------------------------------------------
# Maximum custom-installer upload size in bytes. Default 2 GB.
REPOFABRIC_UPLOAD_MAX_BYTES=2147483648
# Worker pool size (1-32). Editable from Service Configuration once
# setup is complete. Used as the bootstrap default.
REPOFABRIC_BOOTSTRAP_WORKER_POOL_SIZE=4

# ------- Display timezone (FD-026) --------------------------------------
# RepoFabric is the timezone authority for the WHOLE solution: the selected
# zone governs RepoFabric, ConfigFabric (sidecar or cross-host), and DSCForge.
# The canonical selection is service.yaml `timezone` (settings tab); this TZ env
# is the container-OS fallback that a co-hosted ConfigFabric sidecar inherits.
# Use an IANA name (e.g. America/Los_Angeles, America/Denver, America/Chicago,
# America/New_York, UTC). Default is UTC. Never assume a locale-specific zone.
TZ=UTC

# ------- ConfigFabric integration (M6 bolt-on / 0.8.1) ------------------
# All OFF by default; a standalone RepoFabric ignores every var below and is
# byte-identical. Set these only when integrating with ConfigFabric. See the
# 0.8.1 entry in CHANGELOG.md and deploy/integration/ for the full runbook.
#
# Master switch. "true" co-hosts ConfigFabric (absorption) and starts its
# loopback bridge + the CF admin tabs.
CONFIGFABRIC_ENABLED=false
# Shared M2M bolt-on bearer. By contract this is RepoFabric's own publisher
# token: the peer presents it on inbound lock-gate / audit calls, and this host
# presents it on its OUTBOUND lock-gate calls. While integration is enabled,
# inbound calls 401 (before any signature check) if this is unset.
REPOFABRIC_PUBLISHER_TOKEN=
# ConfigFabric's loopback pwsh bridge inside this container (absorption only).
CONFIGFABRIC_PUBLISHER_URL=http://127.0.0.1:8089
# Node -> co-hosted CF bridge auth (absorption) and the compliance dual-write ingest.
CONFIGFABRIC_PUBLISHER_TOKEN=
CONFIGFABRIC_INGEST_TOKEN=
# Pre-deletion lock-gate target. Leave UNSET in absorption mode (CONFIGFABRIC_ENABLED=true):
# the gate then defaults to this host's own admin M2M mount and forwards to the
# co-hosted ledger. For a CROSS-HOST ConfigFabric, set this to the ConfigFabric
# admin BASE ending /admin (e.g. http://configfabric-host:8087/admin), NOT the
# full /api/v1/locks/... endpoint -- the client appends the route itself.
CONFIGFABRIC_LOCKGATE_URL=
# Optional dedicated lock-gate bearer; falls back to REPOFABRIC_PUBLISHER_TOKEN.
CONFIGFABRIC_LOCKGATE_TOKEN=
# Entra group type-ahead prefix for the CF assignment picker.
CONFIGFABRIC_GROUP_PREFIX=

# ------- Cross-host bridge legs (scoped capability tokens) --------------
# Least-privilege M2M tokens for peers reaching this host's publisher bridge.
# Each leg is enabled only when its token is set; unset = leg disabled (fail closed).
#   catalog:read -> GET /api/v1/catalog/*   (ConfigFabric / DSCForge resolvers)
#   audit:write  -> POST /api/audit/events  (peer audit events)
REPOFABRIC_CATALOG_READ_TOKEN=
REPOFABRIC_AUDIT_WRITE_TOKEN=

# ------- Cross-fabric signing (RepoFabric#16, default off) --------------
# When signing.mode != off in service.yaml, RepoFabric reads its key material
# from <state>/signing/ on the state volume (UNRAID host path
# /mnt/user/appdata/repofabric-linux/state/signing/):
#   repofabric.key    - this fabric's ECDSA P-256 private key (never shared)
#   fabric-trust.json - the root-signed trust bundle (public keys)
#   root.pub          - the root public key that signs the bundle
# A missing key degrades to UNSIGNED (a warning is logged), so create that dir
# 0700 and place the material there before enabling signing. See deploy/signing/README.md.
